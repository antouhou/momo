#!/bin/sh
set -eu

LOG="${MOMO_WAYFIRE_LOG:-/tmp/momo-wayfire.log}"
WAYFIRE_CONFIG="${MOMO_SHELL_WAYFIRE_CONFIG:-/usr/lib/momo-shell/wayfire.ini}"

{
  echo "===== momo-shell-wayfire start $(date) ====="
  echo "uid/gid: $(id)"
  echo "wayfire config: ${WAYFIRE_CONFIG}"
  echo "momo-shell is started by the Wayfire autostart plugin via /usr/libexec/momo-shell-session"
} >>"${LOG}" 2>&1

exec wayfire -c "${WAYFIRE_CONFIG}" >>"${LOG}" 2>&1
